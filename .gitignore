# =====================================================
# WorkBridge PH — repository ignore rules
# =====================================================

# ---- Secrets — NEVER commit these ----
# .env contains APP_KEY (decrypts sessions), DB password, mail password.
# Leak-prevention is the #1 reason this file exists.
backend/.env
backend/.env.backup
backend/.env.production
backend/.env.*.local
.env
.env.*
!**/.env.example
!**/.env.production.example

# ---- Auth tokens / generated keys ----
backend/auth.json
backend/storage/*.key
backend/storage/oauth-private.key
backend/storage/oauth-public.key

# ---- Dependencies ----
node_modules/
backend/vendor/

# ---- Build artifacts ----
backend/public/build/
backend/public/hot/
backend/public/storage    # symlink — regenerated via `php artisan storage:link`

# ---- User-uploaded content (regenerates from seeder) ----
backend/storage/app/private/
backend/storage/app/public/avatars/
backend/storage/app/resumes/

# ---- Laravel runtime ----
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/testing/
backend/storage/framework/views/
backend/storage/logs/
backend/bootstrap/cache/

# ---- Test artifacts ----
test-results/
playwright-report/
blob-report/
.phpunit.cache/
backend/.phpunit.cache/
backend/.phpunit.result.cache

# ---- IDE / editor state ----
.idea/
.vscode/
.fleet/
.nova/
.zed/
.cursor/
.phpactor.json
backend/.phpactor.json
*.iml
*.swp
*.swo

# ---- OS noise ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Misc ----
*.tar.gz
*.zip
coverage/
